// Voice-assistant button screen.
//
// Three states + a live mic VU ring:
//   active      — voice session is alive (tinted green, dot enlarges)
//   processing  — STT/LLM/TTS round-trip in flight (amber, dot shrinks)
//   neither     — idle (dark gray, dim dot)
//
//   level       — current mic RMS (0..1), drives a pulsing ring around
//                 the dot so the user can SEE that their voice is being
//                 captured in real time. Pushed by the daemon every
//                 ~100ms from /tmp/os-assistant.level.

export component VoiceScreen inherits Rectangle {
    in property <bool> active: false;
    in property <bool> processing: false;
    in property <float> level: 0.0;
    callback tap;

    border-radius: self.width / 6;

    background: root.processing ? #cc8800
              : root.active ? #1e4d2b
              : #3d3d3d;
    animate background { duration: 250ms; easing: ease-in-out; }

    // VU ring — visible only when active (a session is open and we're
    // listening). Diameter scales 32% → 92% with `level`. Opacity
    // also rises with level so silence ≈ invisible.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width * (0.32 + root.level * 0.60);
        height: self.width;
        border-radius: self.width / 2;
        background: transparent;
        border-width: 2px;
        border-color: white;
        opacity: root.active && !root.processing
                 ? 0.15 + root.level * 0.55
                 : 0.0;
        animate width  { duration: 80ms; easing: ease-out; }
        animate opacity { duration: 120ms; easing: ease-out; }
    }

    // Center dot — base indicator, sized by state.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width * (root.processing ? 0.21
                              : root.active ? 0.38
                              : 0.25);
        height: self.width;
        border-radius: self.width / 2;
        background: white;
        opacity: root.active || root.processing ? 1.0 : 0.6;
        animate width { duration: 220ms; easing: ease-in-out; }
        animate opacity { duration: 220ms; }
    }

    TouchArea {
        clicked => { root.tap(); }
    }
}
